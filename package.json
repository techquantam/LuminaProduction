{
  "name": "lumina-production",
  "version": "1.0.0",
  "description": "Premium Luxury Event Management Website",
  "private": true,
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "install:all": "npm install --workspaces --include-workspace-root",
    "server": "npm run dev --workspace=server",
    "client": "npm run dev --workspace=client",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "build": "npm run build --workspace=client",
    "build:all": "npm run build --workspace=server && npm run build --workspace=client"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
