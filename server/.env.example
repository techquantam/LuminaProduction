# Server Port
PORT=5000

# Node Environment
NODE_ENV=development

# JWT Secret Key
JWT_SECRET=lumina_production_ultra_secret_key_2026

# MongoDB Connection String (Leave blank or omit to auto-fallback to a robust file-based database)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/lumina_db?retryWrites=true&w=majority

# Cloudinary Credentials (Optional - Omit to store uploaded files locally in server/uploads/)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
